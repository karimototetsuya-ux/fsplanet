<!DOCTYPE html>
<html lang="ja" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="{{ settings.fp_main | default: settings.color_main | default: '#62ADED' }}">

  <title>
    {%- if page_title == blank -%}
      {{ shop.name }} — {{ shop.description | default: "家族の時間をもっと豊かに。" }}
    {%- else -%}
      {{ page_title }} | {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <!-- Canonical & Open Graph -->
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  <meta property="og:type" content="website">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | default: shop.name }}">
  {%- if page_description -%}
    <meta name="twitter:description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Google Fonts — Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Noto+Sans+JP:wght@300;400;500;700&display=swap"
    rel="stylesheet"
  >

  <!-- Base CSS (Dawn standard — DO NOT EDIT) -->
  {{ 'base.css' | asset_url | stylesheet_tag }}

  <!-- FP Custom CSS -->
  {{ 'custom.css' | asset_url | stylesheet_tag }}

  <!-- FP Design Tokens (CSS Custom Properties from Theme Settings) -->
  <style>
    :root {
      --fp-main:   {{ settings.fp_main   | default: '#62ADED' }};
      --fp-sub:    {{ settings.fp_sub    | default: '#3E7CB1' }};
      --fp-bg:     {{ settings.fp_bg     | default: '#FCFCFD' }};
      --fp-accent: {{ settings.fp_accent | default: '#CFAE6B' }};
      --fp-btn:    {{ settings.fp_btn    | default: '#4A90E2' }};
      --fp-buy:    {{ settings.fp_buy    | default: '#F2994A' }};
      --fp-text:   {{ settings.fp_text   | default: '#222222' }};
    }
  </style>

  <!-- Shopify required scripts -->
  {{ content_for_header }}

  <!-- Theme JS (Dawn standard — DO NOT EDIT, deferred) -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <!-- FP Custom JS (deferred) -->
  <script src="{{ 'custom.js' | asset_url }}" defer></script>

  {%- if settings.custom_head_code != blank -%}
    {{ settings.custom_head_code }}
  {%- endif -%}
</head>

<body
  class="template-{{ template.name }}{% if customer %} customer-logged-in{% endif %}"
  data-fp-theme="true"
>

  {%- comment -%} スキップリンク（キーボードユーザー向け） {%- endcomment -%}
  <a class="skip-to-content-link button" href="#MainContent">
    コンテンツへスキップ
  </a>

  {%- comment -%}
    ヘッダーグループ
    - sections/fp-header.liquid を header-group に含めるか、
      直接 render または content_for_layout 前に sections タグを使う
  {%- endcomment -%}
  {%- sections 'header-group' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  <!-- Back to Top Button -->
  <button
    class="fp-back-to-top"
    aria-label="ページトップへ戻る"
    aria-hidden="true"
    type="button"
  >
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M3 12l6-6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  {%- if settings.custom_body_end_code != blank -%}
    {{ settings.custom_body_end_code }}
  {%- endif -%}

</body>
</html>
