<!DOCTYPE html>
<html lang="ja" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="{{ settings.color_main }}">

  <title>
    {%- if page_title == blank -%}
      {{ shop.name }} — {{ shop.description | default: "家族の時間をもっと豊かに。" }}
    {%- else -%}
      {{ page_title }} | {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <!-- Canonical & OG -->
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  <meta property="og:type" content="website">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image }}">
  {%- endif -%}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Base CSS -->
  {{ 'base.css' | asset_url | stylesheet_tag }}

  <!-- Content for header -->
  {{ content_for_header }}

  <!-- Theme JS (deferred) -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</head>

<body class="template-{{ template.name }}{% if customer %} customer-logged-in{% endif %}">

  <a class="skip-to-content" href="#MainContent">コンテンツへスキップ</a>

  {%- sections 'header-group' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  <!-- Floating Cart FAB -->
  <div class="fab-cart" id="fabCart" aria-label="カートを見る" role="button" tabindex="0">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="22" height="22"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.932-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/></svg>
    {%- if cart.item_count > 0 -%}
      <span class="fab-badge" aria-label="{{ cart.item_count }}点">{{ cart.item_count }}</span>
    {%- endif -%}
  </div>

  <!-- Back to Top -->
  <button class="back-top" id="backTop" aria-label="ページトップへ戻る">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4.5 15.75l7.5-7.5 7.5 7.5"/></svg>
  </button>

</body>
</html>
