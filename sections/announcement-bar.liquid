{%- if section.settings.show_bar -%}
<div class="announce-bar" role="marquee" aria-label="お知らせ" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <div class="announce-track" id="announceTrack">
    {%- for i in (1..3) -%}
      {%- assign text_key = 'text_' | append: i -%}
      {%- if section.settings[text_key] != blank -%}
        <span>{{ section.settings[text_key] }}</span>
      {%- endif -%}
    {%- endfor -%}
    {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
    {%- for i in (1..3) -%}
      {%- assign text_key = 'text_' | append: i -%}
      {%- if section.settings[text_key] != blank -%}
        <span>{{ section.settings[text_key] }}</span>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<style>
.announce-bar {
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 300;
  letter-spacing: 0.18em;
  overflow: hidden;
  position: relative;
}
.announce-bar span { color: var(--c-accent); margin: 0 32px; white-space: nowrap; }
.announce-track {
  display: flex;
  animation: fsMarquee {{ section.settings.speed }}s linear infinite;
  white-space: nowrap;
  position: absolute;
}
@keyframes fsMarquee {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
</style>

{% schema %}
{
  "name": "お知らせバー",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "表示する",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキスト色",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "テキスト1",
      "default": "🚚 税込5,000円以上で送料無料"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "テキスト2",
      "default": "✨ 新規会員登録で10%OFFクーポンプレゼント"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "テキスト3",
      "default": "🎁 ギフトラッピング無料対応中"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "スクロール速度（秒）",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "お知らせバー"
    }
  ]
}
{% endschema %}
