<section class="insta-section section-pad-sm" aria-labelledby="insta-heading-{{ section.id }}">
  <div class="container">
    <div class="insta-header">
      <span class="section-label en">Instagram</span>
      <h2 class="section-title" id="insta-heading-{{ section.id }}"
          style="font-size:clamp(20px,2.4vw,30px);font-weight:300;">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.handle != blank -%}
        <div class="insta-handle">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          @{{ section.settings.handle }}
        </div>
      {%- endif -%}
    </div>

    <div class="insta-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'photo' -%}
          <a class="insta-item sr sr-delay-{{ forloop.index }}"
             href="{{ block.settings.url | default: section.settings.profile_url | default: '#' }}"
             target="_blank" rel="noopener"
             aria-label="Instagram投稿を見る"
             {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}"
                   alt="{{ block.settings.alt | default: 'Instagram' }}"
                   loading="lazy">
            {%- else -%}
              <div style="height:100%;background:var(--c-surface);display:flex;align-items:center;justify-content:center;font-size:32px;">📷</div>
            {%- endif -%}
            <div class="insta-hover">
              <svg xmlns="http://www.w3.org/2000/svg" fill="white" viewBox="0 0 24 24" width="28" height="28"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_follow_btn and section.settings.profile_url != blank -%}
      <div style="text-align:center;margin-top:36px;">
        <a class="btn btn-outline en" href="{{ section.settings.profile_url }}" target="_blank" rel="noopener">
          Follow @{{ section.settings.handle }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.insta-section { background:var(--c-bg); }
.insta-header { text-align:center; margin-bottom:32px; }
.insta-handle { font-family:var(--f-en); font-size:14px; font-weight:300; color:var(--c-main); letter-spacing:.1em; display:flex; align-items:center; justify-content:center; gap:6px; margin-top:6px; }
.insta-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }
.insta-item { aspect-ratio:1; overflow:hidden; border-radius:var(--radius-s); position:relative; cursor:pointer; }
.insta-item img { width:100%; height:100%; object-fit:cover; transition:transform .5s var(--ease); }
.insta-item:hover img { transform:scale(1.1); }
.insta-hover { position:absolute; inset:0; background:rgba(98,173,237,.6); display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity .3s; }
.insta-item:hover .insta-hover { opacity:1; }
@media (max-width:900px){ .insta-grid { grid-template-columns:repeat(3,1fr); } }
</style>

{% schema %}
{
  "name": "Instagramグリッド",
  "class": "section-instagram",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "暮らしのスナップ"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagramハンドル（@なし）",
      "default": "fsplanet_official"
    },
    {
      "type": "url",
      "id": "profile_url",
      "label": "InstagramプロフィールURL"
    },
    {
      "type": "checkbox",
      "id": "show_follow_btn",
      "label": "フォローボタンを表示",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "写真",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "写真"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "ALTテキスト"
        },
        {
          "type": "url",
          "id": "url",
          "label": "投稿へのリンク"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagramグリッド",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
