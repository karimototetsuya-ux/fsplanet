{%- assign collection = collections[section.settings.collection] -%}

<section class="feat-col-section section-pad{% if section.settings.bg_warm %} feat-col--warm{% endif %}"
         aria-labelledby="feat-col-heading-{{ section.id }}">
  <div class="container">

    <div class="section-head flex-between" style="text-align:left;margin-bottom:clamp(28px,4vw,48px);">
      <div>
        <span class="section-label en">{{ section.settings.label }}</span>
        <h2 class="section-title" id="feat-col-heading-{{ section.id }}"
            style="font-size:clamp(22px,2.8vw,36px);">
          {{ section.settings.heading }}
        </h2>
      </div>
      {%- if section.settings.show_view_all and collection != blank -%}
        <a class="btn-link en" href="{{ collection.url }}">
          {{ section.settings.view_all_label | default: 'View All' }}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="14" height="14" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="product-grid-4">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {%- render 'product-card', product: product, index: forloop.index -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="prod-card sr sr-delay-{{ i }}">
              <div class="prod-img-wrap" style="background:var(--c-surface);"></div>
              <div class="prod-info">
                <div class="prod-name" style="background:var(--c-surface);height:14px;border-radius:4px;"></div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- else -%}
        <p style="color:var(--c-text3);font-size:13px;">コレクションを設定してください。</p>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
.feat-col-section { background: var(--c-bg); }
.feat-col--warm   { background: var(--c-warm); }
.product-grid-4 {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 24px;
}
@media (max-width:900px){ .product-grid-4 { grid-template-columns:repeat(2,1fr); } }
@media (max-width:480px){ .product-grid-4 { grid-template-columns:repeat(2,1fr); gap:12px; } }
</style>

{% schema %}
{
  "name": "商品コレクション",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "ラベル（英語）",
      "default": "New Arrival"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "新着アイテム"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "コレクション"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示商品数",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「もっと見る」リンクを表示",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "「もっと見る」テキスト",
      "default": "View All"
    },
    {
      "type": "checkbox",
      "id": "bg_warm",
      "label": "ウォーム背景色を使用",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "新着アイテム",
      "settings": {
        "label": "New Arrival",
        "heading": "新着アイテム"
      }
    },
    {
      "name": "ベストセラー",
      "settings": {
        "label": "Best Sellers",
        "heading": "人気ランキング",
        "bg_warm": true
      }
    }
  ]
}
{% endschema %}
