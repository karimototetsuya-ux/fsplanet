<footer class="footer" role="contentinfo">
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <!-- Brand Column -->
        <div class="footer-brand">
          {%- if settings.footer_logo != blank -%}
            <a href="{{ routes.root_url }}" class="footer-logo-img">
              <img src="{{ settings.footer_logo | image_url: width: 160 }}" alt="{{ shop.name }}" loading="lazy">
            </a>
          {%- else -%}
            <div class="footer-logo en">F'<span>s</span>Planet</div>
          {%- endif -%}
          {%- if settings.footer_description != blank -%}
            <div class="footer-tagline">{{ settings.footer_description }}</div>
          {%- endif -%}
          <div class="footer-sns" role="list" aria-label="SNSリンク">
            {%- if settings.social_instagram != blank -%}
              <a class="sns-btn" href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" role="listitem">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_twitter != blank -%}
              <a class="sns-btn" href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X (Twitter)" role="listitem">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M4 4l16 16M4 20L20 4"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook != blank -%}
              <a class="sns-btn" href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" role="listitem">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_youtube != blank -%}
              <a class="sns-btn" href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube" role="listitem">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        <!-- Link Columns -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_column' -%}
            <div {{ block.shopify_attributes }}>
              <div class="footer-col-title">{{ block.settings.title }}</div>
              <div class="footer-links">
                {%- if block.settings.menu != blank -%}
                  {%- for link in block.settings.menu.links -%}
                    <a class="footer-link" href="{{ link.url }}">{{ link.title }}</a>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        <!-- App Download -->
        {%- if settings.footer_show_app_badges -%}
          <div>
            <div class="footer-col-title">アプリ</div>
            <p class="footer-app-title">公式アプリをダウンロード</p>
            <div class="app-badges">
              <div class="app-badge">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="white" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <div class="app-badge-text">
                  <span class="app-badge-sub">Download on the</span>
                  <span class="app-badge-name">App Store</span>
                </div>
              </div>
              <div class="app-badge">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M3.18 23.76a2 2 0 001.07-.3l12.44-7.02-2.79-2.79-10.72 10.11zM.64 1.34A2 2 0 000 2.83v18.34a2 2 0 00.64 1.49l.08.08L11.08 12v-.25L.72 1.26l-.08.08zM21.38 10.57l-3.2-1.8-3.14 3.14 3.14 3.14 3.23-1.82a2 2 0 000-2.66zM4.25.54l12.44 7.02-2.79 2.79L3.18.24A2 2 0 004.25.54z"/></svg>
                <div class="app-badge-text">
                  <span class="app-badge-sub">Get it on</span>
                  <span class="app-badge-name">Google Play</span>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="container">
    <div class="footer-bottom">
      <span class="footer-copy en">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      {%- if settings.footer_show_payment -%}
        <div class="payment-icons" aria-label="対応支払い方法">
          {%- for type in shop.enabled_payment_types -%}
            <div class="payment-icon">{{ type | payment_type_svg_tag: scale: 1 }}</div>
          {%- endfor -%}
        </div>
      {%- endif -%}
      <div class="footer-bottom-links">
        {%- if section.settings.bottom_menu != blank -%}
          {%- for link in section.settings.bottom_menu.links -%}
            <a class="footer-bottom-link" href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<style>
.footer { background:#111111; color:rgba(255,255,255,.65); }
.footer-main { padding:clamp(60px,8vw,100px) 0 clamp(40px,5vw,60px); }
.footer-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr 1.5fr; gap:48px; }
.footer-logo { font-family:var(--f-en); font-size:20px; font-weight:300; letter-spacing:.18em; color:#fff; margin-bottom:14px; display:block; }
.footer-logo span { color:var(--c-main); }
.footer-logo-img img { height:36px; width:auto; object-fit:contain; margin-bottom:14px; }
.footer-tagline { font-size:13px; font-weight:300; color:rgba(255,255,255,.5); line-height:1.9; letter-spacing:var(--ls); margin-bottom:24px; }
.footer-sns { display:flex; gap:10px; }
.sns-btn { width:36px; height:36px; border:1px solid rgba(255,255,255,.15); border-radius:50%; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,.5); transition:all .2s; }
.sns-btn:hover { border-color:var(--c-main); color:var(--c-main); background:rgba(98,173,237,.08); }
.footer-col-title { font-size:11px; font-weight:500; letter-spacing:.2em; text-transform:uppercase; color:#fff; margin-bottom:18px; }
.footer-links { display:flex; flex-direction:column; gap:10px; }
.footer-link { font-size:13px; font-weight:300; color:rgba(255,255,255,.5); letter-spacing:var(--ls); transition:color .2s; }
.footer-link:hover { color:rgba(255,255,255,.9); }
.footer-app-title { font-size:12px; color:rgba(255,255,255,.5); margin-bottom:12px; }
.app-badges { display:flex; flex-direction:column; gap:8px; }
.app-badge { display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid rgba(255,255,255,.15); border-radius:var(--radius-s); cursor:pointer; transition:all .2s; }
.app-badge:hover { border-color:rgba(255,255,255,.35); background:rgba(255,255,255,.04); }
.app-badge-text { display:flex; flex-direction:column; }
.app-badge-sub { font-size:9px; color:rgba(255,255,255,.45); letter-spacing:.08em; }
.app-badge-name { font-size:13px; font-weight:400; color:#fff; }
.footer-bottom { border-top:1px solid rgba(255,255,255,.08); padding:24px 0; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
.footer-copy { font-size:11px; color:rgba(255,255,255,.3); letter-spacing:var(--ls); }
.footer-bottom-links { display:flex; gap:20px; }
.footer-bottom-link { font-size:11px; color:rgba(255,255,255,.3); transition:color .2s; }
.footer-bottom-link:hover { color:rgba(255,255,255,.6); }
.payment-icons { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
.payment-icon svg { height:24px; width:auto; }
@media (max-width:1100px){ .footer-grid { grid-template-columns:1.5fr 1fr 1fr; } }
@media (max-width:900px){ .footer-grid { grid-template-columns:1fr 1fr; } }
@media (max-width:640px){ .footer-grid { grid-template-columns:1fr; } }
</style>

{% schema %}
{
  "name": "フッター",
  "class": "section-footer",
  "settings": [
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "フッター下部リンク",
      "default": "footer"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "リンクカラム",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "カラムタイトル"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "メニュー"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "フッター"
    }
  ]
}
{% endschema %}
