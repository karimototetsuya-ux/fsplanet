{%- liquid
  assign autoplay       = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | default: 6000
  assign slide_count    = section.blocks | where: 'type', 'slide' | size
-%}

<section
  class="fp-hero"
  id="fp-hero-{{ section.id }}"
  aria-label="{{ 'sections.hero.label' | t | default: 'ヒーロー' }}"
  data-autoplay="{{ autoplay }}"
  data-speed="{{ autoplay_speed }}"
  data-slides="{{ slide_count }}"
>
  <div class="fp-hero__track" id="fp-hero-track-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- liquid
          assign bg_img     = block.settings.image
          assign eyebrow    = block.settings.eyebrow
          assign title      = block.settings.title
          assign subtitle   = block.settings.subtitle
          assign btn1_label = block.settings.btn1_label
          assign btn1_url   = block.settings.btn1_url
          assign btn2_label = block.settings.btn2_label
          assign btn2_url   = block.settings.btn2_url
          assign overlay_op = block.settings.overlay_opacity | default: 55
          assign text_align = block.settings.text_align | default: 'left'
        -%}
        <div
          class="fp-hero__slide{% if forloop.first %} is-active{% endif %}"
          role="group"
          aria-roledescription="slide"
          aria-label="{{ forloop.index }} / {{ slide_count }}"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Background image {%- endcomment -%}
          <div
            class="fp-hero__bg"
            style="
              {%- if bg_img -%}
                background-image: url('{{ bg_img | image_url: width: 1920 }}');
              {%- else -%}
                background: linear-gradient(135deg, #1a2533 0%, #2c4a6e 100%);
              {%- endif -%}
            "
          >
            {%- if bg_img -%}
              <img
                src="{{ bg_img | image_url: width: 1920 }}"
                srcset="
                  {{ bg_img | image_url: width: 750 }} 750w,
                  {{ bg_img | image_url: width: 1100 }} 1100w,
                  {{ bg_img | image_url: width: 1500 }} 1500w,
                  {{ bg_img | image_url: width: 1920 }} 1920w
                "
                sizes="100vw"
                alt="{{ bg_img.alt | escape | default: title }}"
                loading="{{ forloop.first | iif: 'eager', 'lazy' }}"
                fetchpriority="{{ forloop.first | iif: 'high', 'low' }}"
                width="{{ bg_img.width }}"
                height="{{ bg_img.height }}"
                class="fp-hero__bg-img"
              >
            {%- endif -%}
          </div>

          {%- comment -%} Gradient overlay {%- endcomment -%}
          <div
            class="fp-hero__overlay"
            style="opacity: {{ overlay_op | divided_by: 100.0 }}"
            aria-hidden="true"
          ></div>

          {%- comment -%} Content {%- endcomment -%}
          <div class="fp-hero__content fp-hero__content--{{ text_align }}">
            {%- if eyebrow != blank -%}
              <p class="fp-hero__eyebrow">{{ eyebrow }}</p>
            {%- endif -%}

            {%- if title != blank -%}
              <h2 class="fp-hero__title">{{ title | newline_to_br }}</h2>
            {%- endif -%}

            {%- if subtitle != blank -%}
              <p class="fp-hero__subtitle">{{ subtitle | newline_to_br }}</p>
            {%- endif -%}

            {%- if btn1_label != blank or btn2_label != blank -%}
              <div class="fp-hero__cta">
                {%- if btn1_label != blank -%}
                  <a
                    href="{{ btn1_url | default: '#' }}"
                    class="fp-hero__btn fp-hero__btn--primary"
                    {% if btn1_url == blank %}aria-disabled="true"{% endif %}
                  >
                    {{ btn1_label }}
                    <svg width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
                      <path d="M1 5h14M10 1l5 4-5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endif -%}
                {%- if btn2_label != blank -%}
                  <a
                    href="{{ btn2_url | default: '#' }}"
                    class="fp-hero__btn fp-hero__btn--secondary"
                    {% if btn2_url == blank %}aria-disabled="true"{% endif %}
                  >
                    {{ btn2_label }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if slide_count > 1 -%}
    {%- comment -%} Dot navigation {%- endcomment -%}
    <div class="fp-hero__controls" aria-label="{{ 'sections.hero.slide_navigation' | t | default: 'スライドナビゲーション' }}">
      <div class="fp-hero__dots" role="tablist">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <button
              class="fp-hero__dot{% if forloop.first %} is-active{% endif %}"
              role="tab"
              aria-selected="{{ forloop.first }}"
              aria-label="{{ 'sections.hero.go_to_slide' | t: number: forloop.index | default: 'スライド ' | append: forloop.index }}"
              data-index="{{ forloop.index0 }}"
            ></button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="fp-hero__arrows">
        <button
          class="fp-hero__arrow fp-hero__arrow--prev"
          aria-label="{{ 'sections.hero.previous_slide' | t | default: '前のスライド' }}"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M11 3L5 9l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          class="fp-hero__arrow fp-hero__arrow--next"
          aria-label="{{ 'sections.hero.next_slide' | t | default: '次のスライド' }}"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M7 3l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    {%- comment -%} Scroll hint {%- endcomment -%}
    <div class="fp-hero__scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <div class="fp-hero__scroll-line"></div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "ヒーロースライドショー",
  "tag": "section",
  "class": "fp-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "スライド設定"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "自動再生",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "自動再生間隔（ミリ秒）",
      "min": 3000,
      "max": 10000,
      "step": 500,
      "default": 6000
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "スライド",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "背景画像"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "オーバーレイ濃度（%）",
          "min": 0,
          "max": 90,
          "step": 5,
          "default": 55
        },
        {
          "type": "header",
          "content": "テキスト"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "上部テキスト（英字）",
          "default": "New Summer Collection 2025"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "メインタイトル",
          "default": "家族の時間を\nもっと豊かに。"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "サブテキスト",
          "default": "上質なアイテムで、毎日の暮らしに\n小さな幸せを届けます。"
        },
        {
          "type": "header",
          "content": "ボタン 1"
        },
        {
          "type": "text",
          "id": "btn1_label",
          "label": "ボタン1 テキスト",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn1_url",
          "label": "ボタン1 リンク"
        },
        {
          "type": "header",
          "content": "ボタン 2"
        },
        {
          "type": "text",
          "id": "btn2_label",
          "label": "ボタン2 テキスト",
          "default": "New Arrivals"
        },
        {
          "type": "url",
          "id": "btn2_url",
          "label": "ボタン2 リンク"
        },
        {
          "type": "header",
          "content": "レイアウト"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "テキスト位置",
          "options": [
            { "value": "left",   "label": "左寄せ" },
            { "value": "center", "label": "中央" },
            { "value": "right",  "label": "右寄せ" }
          ],
          "default": "left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ヒーロースライドショー",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New Summer Collection 2025",
            "title": "家族の時間を\nもっと豊かに。",
            "subtitle": "上質なアイテムで、毎日の暮らしに\n小さな幸せを届けます。",
            "btn1_label": "Shop Now",
            "btn2_label": "New Arrivals"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Gift Season Special",
            "title": "大切な人への\n贈りもの。",
            "subtitle": "心を込めたギフトで、\n特別な瞬間を彩る。",
            "btn1_label": "Gift Guide",
            "btn2_label": "View All"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Home & Lifestyle",
            "title": "暮らしを整える、\n上質な日用品。",
            "subtitle": "こだわりのインテリアと雑貨で、\nお家の時間を豊かに。",
            "btn1_label": "Explore Home",
            "btn2_label": "Sale Items"
          }
        }
      ]
    }
  ]
}
{% endschema %}
