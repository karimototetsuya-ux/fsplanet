<section class="cat-section section-pad-sm" aria-labelledby="cat-heading-{{ section.id }}">
  <div class="container">
    {%- if section.settings.show_heading -%}
      <div class="section-head">
        <span class="section-label en">{{ section.settings.label }}</span>
        <h2 class="section-title-ja sr" id="cat-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="cat-grid cat-grid--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <a class="cat-item sr sr-delay-{{ forloop.index }}"
             href="{{ block.settings.url | default: '#' }}"
             aria-label="{{ block.settings.name_ja }}カテゴリ"
             {{ block.shopify_attributes }}>

            <div class="cat-icon-wrap cat-icon--{{ forloop.index }}">
              {%- if block.settings.icon_image != blank -%}
                <img src="{{ block.settings.icon_image | image_url: width: 60 }}"
                     alt="{{ block.settings.name_en }}"
                     width="30" height="30" loading="lazy">
              {%- else -%}
                {{ block.settings.icon_svg }}
              {%- endif -%}
            </div>

            <div class="cat-name">
              <span class="cat-name-en">{{ block.settings.name_en }}</span>
              {{ block.settings.name_ja }}
            </div>

          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.cat-section { background: var(--c-bg); }
.cat-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 20px;
}
.cat-grid--4 { grid-template-columns: repeat(4, 1fr); }
.cat-grid--5 { grid-template-columns: repeat(5, 1fr); }
.cat-item {
  display: flex; flex-direction: column; align-items: center;
  gap: 14px; cursor: pointer; padding: 24px 12px 20px;
  border-radius: var(--radius-m);
  border: 1px solid transparent;
  transition: all .28s var(--ease);
  text-decoration: none;
}
.cat-item:hover { border-color:var(--c-border); background:#fff; box-shadow:var(--shadow-m); transform:translateY(-4px); }
.cat-icon-wrap { width:72px; height:72px; border-radius:50%; display:flex; align-items:center; justify-content:center; transition:all .28s; position:relative; }
.cat-icon-wrap svg { width:30px; height:30px; position:relative; z-index:1; }
.cat-icon--1 { background:rgba(207,174,107,.12); } .cat-item:hover .cat-icon--1 { background:rgba(207,174,107,.22); }
.cat-icon--2 { background:rgba(98,173,237,.10); }  .cat-item:hover .cat-icon--2 { background:rgba(98,173,237,.20); }
.cat-icon--3 { background:rgba(220,157,180,.12); } .cat-item:hover .cat-icon--3 { background:rgba(220,157,180,.22); }
.cat-icon--4 { background:rgba(90,120,160,.10); }  .cat-item:hover .cat-icon--4 { background:rgba(90,120,160,.20); }
.cat-icon--5 { background:rgba(152,195,130,.10); } .cat-item:hover .cat-icon--5 { background:rgba(152,195,130,.20); }
.cat-icon--6 { background:rgba(230,160,95,.10); }  .cat-item:hover .cat-icon--6 { background:rgba(230,160,95,.20); }
.cat-name { font-size:11px; font-weight:400; letter-spacing:var(--ls); color:var(--c-text2); text-align:center; line-height:1.5; transition:color .2s; }
.cat-name-en { font-family:var(--f-en); font-size:14px; font-weight:300; letter-spacing:.12em; color:var(--c-text); display:block; margin-bottom:2px; }
.cat-item:hover .cat-name { color:var(--c-main); }
@media (max-width:900px){ .cat-grid { grid-template-columns:repeat(3,1fr); } }
@media (max-width:480px){ .cat-grid { grid-template-columns:repeat(3,1fr); gap:10px; } .cat-icon-wrap{ width:54px; height:54px; } }
</style>

{% schema %}
{
  "name": "カテゴリグリッド",
  "class": "section-category-grid",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "見出しを表示",
      "default": true
    },
    {
      "type": "text",
      "id": "label",
      "label": "ラベル（英語）",
      "default": "Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し（日本語）",
      "default": "カテゴリから探す"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "カテゴリ",
      "settings": [
        {
          "type": "text",
          "id": "name_en",
          "label": "カテゴリ名（英語）",
          "default": "Gift"
        },
        {
          "type": "text",
          "id": "name_ja",
          "label": "カテゴリ名（日本語）",
          "default": "ギフト"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先URL"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "アイコン画像（推奨: 60x60px）"
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "SVGアイコン（画像なしの場合）"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "カテゴリグリッド",
      "blocks": [
        { "type": "category", "settings": { "name_en": "Gift", "name_ja": "ギフト" } },
        { "type": "category", "settings": { "name_en": "Kids & Baby", "name_ja": "キッズ・ベビー" } },
        { "type": "category", "settings": { "name_en": "Women", "name_ja": "ウィメンズ" } },
        { "type": "category", "settings": { "name_en": "Men", "name_ja": "メンズ" } },
        { "type": "category", "settings": { "name_en": "Home", "name_ja": "インテリア・雑貨" } },
        { "type": "category", "settings": { "name_en": "Food & Drink", "name_ja": "フード・ドリンク" } }
      ]
    }
  ]
}
{% endschema %}
