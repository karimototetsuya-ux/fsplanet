<section class="gift-section section-pad" aria-labelledby="gift-heading-{{ section.id }}">
  <div class="container">
    <div class="section-head">
      <span class="section-label en">{{ section.settings.label }}</span>
      <h2 class="section-title sr" id="gift-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtext != blank -%}
        <p class="section-desc sr sr-delay-2" style="margin-top:14px;max-width:520px;margin-left:auto;margin-right:auto;">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}
    </div>

    <div class="gift-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <a class="gift-card sr sr-delay-{{ forloop.index | times: 2 | minus: 1 }}"
             href="{{ block.settings.url | default: '#' }}"
             {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}"
                   alt="{{ block.settings.title }}" loading="lazy">
            {%- else -%}
              <div style="height:100%;background:linear-gradient(160deg,#2c4a6e,#4a7fb5);"></div>
            {%- endif -%}
            <div class="gift-overlay"></div>
            <div class="gift-card-content">
              {%- if block.settings.price_range != blank -%}
                <span class="gift-price-range en">{{ block.settings.price_range }}</span>
              {%- endif -%}
              <div class="gift-title en">{{ block.settings.title }}</div>
              <span class="gift-btn en">
                {{ block.settings.btn_label | default: 'Shop Now' }}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="12" height="12" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.gift-section { background:var(--c-warm); }
.gift-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.gift-card { border-radius:var(--radius-m); overflow:hidden; position:relative; cursor:pointer; aspect-ratio:3/4; display:block; }
.gift-card img { width:100%; height:100%; object-fit:cover; transition:transform .7s var(--ease); }
.gift-card:hover img { transform:scale(1.06); }
.gift-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(20,20,20,.72) 0%,transparent 55%); }
.gift-card-content { position:absolute; bottom:0; left:0; right:0; padding:28px; }
.gift-price-range { font-family:var(--f-en); font-size:10px; font-weight:300; letter-spacing:.2em; text-transform:uppercase; color:var(--c-accent); margin-bottom:8px; display:block; }
.gift-title { font-family:var(--f-en); font-size:clamp(18px,2vw,26px); font-weight:300; color:#fff; letter-spacing:.04em; line-height:1.25; margin-bottom:14px; }
.gift-btn { display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,.18); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.35); color:#fff; padding:10px 18px; border-radius:2px; font-size:11px; letter-spacing:.14em; text-transform:uppercase; transition:all .25s; font-family:var(--f-en); }
.gift-card:hover .gift-btn { background:rgba(255,255,255,.28); }
@media (max-width:900px){ .gift-grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:640px){ .gift-grid { grid-template-columns:1fr; } }
</style>

{% schema %}
{
  "name": "ギフトガイド",
  "class": "section-gift-guide",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "ラベル（英語）",
      "default": "Gift Guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "贈りものガイド"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "サブテキスト",
      "default": "シーンや予算に合わせた、とっておきのギフトをご提案します。"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "ギフトカード",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "背景画像"
        },
        {
          "type": "text",
          "id": "price_range",
          "label": "価格帯",
          "default": "¥3,000 – ¥5,000"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "Birthday Gift"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先URL"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "ボタンテキスト",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ギフトガイド",
      "blocks": [
        { "type": "card", "settings": { "price_range": "¥3,000 – ¥5,000", "title": "Birthday Gift" } },
        { "type": "card", "settings": { "price_range": "¥5,000 – ¥10,000", "title": "Wedding Gift" } },
        { "type": "card", "settings": { "price_range": "¥10,000+", "title": "Luxury Gift" } }
      ]
    }
  ]
}
{% endschema %}
