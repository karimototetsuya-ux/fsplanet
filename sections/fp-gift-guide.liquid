{%- liquid
  assign pt = section.settings.padding_top    | default: 80
  assign pb = section.settings.padding_bottom | default: 80
-%}

<section
  class="fp-gift"
  id="fp-gift-{{ section.id }}"
  aria-labelledby="fp-gift-heading-{{ section.id }}"
  style="
    --fp-gift-bg: {{ section.settings.bg_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  "
>
  <div class="fp-container">

    <div class="fp-section-head fp-sr">
      {%- if section.settings.label != blank -%}
        <span class="fp-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="fp-section-title" id="fp-gift-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="fp-section-desc" style="margin-top:12px">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <ul class="fp-gift__grid" role="list" aria-label="{{ section.settings.heading }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <li
            class="fp-sr"
            style="animation-delay: {{ forloop.index0 | times: 0.1 }}s"
            {{ block.shopify_attributes }}
          >
            <a
              href="{{ block.settings.btn_url | default: '#' }}"
              class="fp-gift__card"
              aria-label="{{ block.settings.title | escape }}"
            >
              <div class="fp-gift__card-img" aria-hidden="true">
                {%- if block.settings.image -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 640 }}"
                    srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 640 }} 640w"
                    sizes="(max-width:768px) 90vw, 400px"
                    alt="{{ block.settings.image.alt | escape | default: block.settings.title }}"
                    width="640" height="853"
                    loading="lazy"
                    class="fp-gift__img"
                  >
                {%- else -%}
                  <div class="fp-gift__img-placeholder fp-gift__img-placeholder--{{ forloop.index }}"></div>
                {%- endif -%}
              </div>
              <div class="fp-gift__overlay" aria-hidden="true"></div>
              <div class="fp-gift__content">
                {%- if block.settings.price_range != blank -%}
                  <span class="fp-gift__price-range">{{ block.settings.price_range }}</span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="fp-gift__title">{{ block.settings.title | newline_to_br }}</h3>
                {%- endif -%}
                {%- if block.settings.btn_label != blank -%}
                  <span class="fp-gift__btn" aria-hidden="true">
                    {{ block.settings.btn_label }}
                    <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                      <path d="M1 4h12M8.5 1l3.5 3-3.5 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {%- endif -%}
              </div>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</section>

{% schema %}
{
  "name": "Gift Guide",
  "tag": "section",
  "class": "fp-gift-section",
  "settings": [
    {
      "type": "header",
      "content": "見出し"
    },
    {
      "type": "text",
      "id": "label",
      "label": "ラベル（英字）",
      "default": "Gift Guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "贈りものガイド"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "サブテキスト",
      "default": "シーンや予算に合わせた、とっておきのギフトをご提案します。"
    },
    {
      "type": "header",
      "content": "デザイン"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#FBF8F4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上余白（px）",
      "min": 0, "max": 160, "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下余白（px）",
      "min": 0, "max": 160, "step": 8,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "ギフトカード",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "カード画像"
        },
        {
          "type": "text",
          "id": "price_range",
          "label": "価格帯",
          "default": "¥3,000 – ¥5,000"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "タイトル",
          "default": "Birthday\nGift"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "ボタンテキスト",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "ボタンURL"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Gift Guide",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "price_range": "¥3,000 – ¥5,000",
            "title": "Birthday\nGift",
            "btn_label": "Shop Now"
          }
        },
        {
          "type": "card",
          "settings": {
            "price_range": "¥5,000 – ¥10,000",
            "title": "Wedding\nGift",
            "btn_label": "Shop Now"
          }
        },
        {
          "type": "card",
          "settings": {
            "price_range": "¥10,000+",
            "title": "Luxury\nGift",
            "btn_label": "Shop Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
