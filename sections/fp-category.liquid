{%- liquid
  assign section_label = section.settings.label   | default: 'Category'
  assign section_title = section.settings.heading  | default: 'カテゴリから探す'
  assign pt = section.settings.padding_top    | default: 80
  assign pb = section.settings.padding_bottom | default: 80
-%}

<section
  class="fp-cat"
  id="fp-cat-{{ section.id }}"
  aria-labelledby="fp-cat-heading-{{ section.id }}"
  style="
    --fp-cat-bg: {{ section.settings.bg_color }};
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  "
>
  <div class="fp-container">

    {%- if section.settings.show_heading -%}
      <div class="fp-section-head fp-sr" aria-hidden="false">
        <span class="fp-section-label">{{ section_label }}</span>
        <h2 class="fp-section-title" id="fp-cat-heading-{{ section.id }}">{{ section_title }}</h2>
      </div>
    {%- endif -%}

    <ul
      class="fp-cat__grid"
      role="list"
      aria-label="{{ section_title }}"
      style="--fp-cat-cols: {{ section.blocks.size | at_most: 6 }}"
    >
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- liquid
            assign name_en  = block.settings.name_en
            assign name_ja  = block.settings.name_ja
            assign cat_url  = block.settings.url
            assign cat_img  = block.settings.image
            assign icon_bg  = block.settings.icon_bg_color
            assign icon_mod = 'ci-' | append: forloop.index
          -%}
          <li
            class="fp-sr"
            style="animation-delay: {{ forloop.index0 | times: 0.08 }}s"
            {{ block.shopify_attributes }}
          >
            <a
              href="{{ cat_url | default: '#' }}"
              class="fp-cat__item"
              aria-label="{{ name_en }} — {{ name_ja }}"
            >
              <div
                class="fp-cat__icon-wrap fp-cat__icon-{{ forloop.index }}"
                aria-hidden="true"
                {%- if icon_bg != blank -%}
                  style="background-color: {{ icon_bg }}20"
                {%- endif -%}
              >
                {%- if cat_img -%}
                  <img
                    src="{{ cat_img | image_url: width: 144 }}"
                    alt="{{ name_en }}"
                    width="72"
                    height="72"
                    loading="lazy"
                    class="fp-cat__icon-img"
                  >
                {%- else -%}
                  {%- case forloop.index -%}
                    {%- when 1 -%}
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:{{ icon_bg | default: '#CFAE6B' }}">
                        <path d="M9 4l2 4h8l2-4"/>
                        <rect x="4" y="8" width="22" height="18" rx="2"/>
                        <path d="M15 14v6M12 17h6"/>
                      </svg>
                    {%- when 2 -%}
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:{{ icon_bg | default: '#62ADED' }}">
                        <circle cx="15" cy="11" r="5"/>
                        <path d="M6 26c0-4.4 4-8 9-8s9 3.6 9 8"/>
                        <circle cx="22" cy="9" r="3"/>
                      </svg>
                    {%- when 3 -%}
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:{{ icon_bg | default: '#DC9DB4' }}">
                        <path d="M9 6c0 0 0 8 6 8s6-8 6-8"/>
                        <path d="M6 26c0-4.4 4-8 9-8s9 3.6 9 8"/>
                      </svg>
                    {%- when 4 -%}
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:{{ icon_bg | default: '#5A78A0' }}">
                        <rect x="7" y="4" width="16" height="22" rx="1"/>
                        <path d="M11 4v22M15 10h4M15 14h4M15 18h4"/>
                      </svg>
                    {%- when 5 -%}
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:{{ icon_bg | default: '#98C382' }}">
                        <rect x="4" y="10" width="22" height="16" rx="2"/>
                        <path d="M10 10V7a5 5 0 0 1 10 0v3"/>
                        <circle cx="15" cy="18" r="2"/>
                      </svg>
                    {%- else -%}
                      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:{{ icon_bg | default: '#E6A05F' }}">
                        <path d="M6 8h18M6 8c0 8 4 14 9 14S24 16 24 8"/>
                        <path d="M12 8V5a2 2 0 0 1 6 0v3"/>
                      </svg>
                  {%- endcase -%}
                {%- endif -%}
              </div>

              <div class="fp-cat__name">
                {%- if name_en != blank -%}
                  <span class="fp-cat__name-en">{{ name_en }}</span>
                {%- endif -%}
                {%- if name_ja != blank -%}
                  <span class="fp-cat__name-ja">{{ name_ja }}</span>
                {%- endif -%}
              </div>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</section>

{% schema %}
{
  "name": "カテゴリグリッド",
  "tag": "section",
  "class": "fp-cat-section",
  "settings": [
    {
      "type": "header",
      "content": "セクション見出し"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "見出しを表示",
      "default": true
    },
    {
      "type": "text",
      "id": "label",
      "label": "ラベル（英字）",
      "default": "Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "カテゴリから探す"
    },
    {
      "type": "header",
      "content": "デザイン"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#FCFCFD"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上余白（px）",
      "min": 0, "max": 160, "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下余白（px）",
      "min": 0, "max": 160, "step": 8,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "カテゴリ",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "アイコン画像（任意）"
        },
        {
          "type": "text",
          "id": "name_en",
          "label": "カテゴリ名（英字）",
          "default": "Gift"
        },
        {
          "type": "text",
          "id": "name_ja",
          "label": "カテゴリ名（日本語）",
          "default": "ギフト"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先URL"
        },
        {
          "type": "color",
          "id": "icon_bg_color",
          "label": "アイコン背景色",
          "default": "#CFAE6B"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "カテゴリグリッド",
      "blocks": [
        { "type": "category", "settings": { "name_en": "Gift",        "name_ja": "ギフト",          "icon_bg_color": "#CFAE6B" } },
        { "type": "category", "settings": { "name_en": "Kids & Baby", "name_ja": "キッズ・ベビー",  "icon_bg_color": "#62ADED" } },
        { "type": "category", "settings": { "name_en": "Women",       "name_ja": "ウィメンズ",      "icon_bg_color": "#DC9DB4" } },
        { "type": "category", "settings": { "name_en": "Men",         "name_ja": "メンズ",          "icon_bg_color": "#5A78A0" } },
        { "type": "category", "settings": { "name_en": "Home",        "name_ja": "インテリア・雑貨", "icon_bg_color": "#98C382" } },
        { "type": "category", "settings": { "name_en": "Food & Drink","name_ja": "フード・ドリンク", "icon_bg_color": "#E6A05F" } }
      ]
    }
  ]
}
{% endschema %}
