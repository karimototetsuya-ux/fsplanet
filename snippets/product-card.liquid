{%- comment -%}
  Product Card Snippet
  Usage: {% render 'product-card', product: product, index: forloop.index %}
{%- endcomment -%}

{%- assign delay_class = '' -%}
{%- if index == 1 -%}{%- assign delay_class = '' -%}
{%- elsif index == 2 -%}{%- assign delay_class = ' sr-delay-2' -%}
{%- elsif index == 3 -%}{%- assign delay_class = ' sr-delay-3' -%}
{%- elsif index == 4 -%}{%- assign delay_class = ' sr-delay-4' -%}
{%- endif -%}

<div class="prod-card sr{{ delay_class }}">

  <div class="prod-img-wrap">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 480 }}"
           srcset="{{ product.featured_image | image_url: width: 240 }} 240w,
                   {{ product.featured_image | image_url: width: 480 }} 480w,
                   {{ product.featured_image | image_url: width: 720 }} 720w"
           sizes="(max-width:640px) 50vw, (max-width:1200px) 25vw, 300px"
           alt="{{ product.featured_image.alt | default: product.title | escape }}"
           width="480" height="640"
           loading="lazy">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    <!-- Badges -->
    <div class="prod-badges">
      {%- if product.available == false -%}
        <span class="prod-badge pb-limited">SOLD OUT</span>
      {%- elsif product.compare_at_price > product.price -%}
        <span class="prod-badge pb-sale">SALE</span>
      {%- elsif product.tags contains 'new' or product.tags contains 'new-arrival' -%}
        <span class="prod-badge pb-new">New</span>
      {%- elsif product.tags contains 'bestseller' or product.tags contains 'best-seller' -%}
        <span class="prod-badge pb-best">人気</span>
      {%- endif -%}
    </div>

    <!-- Wishlist -->
    {%- if settings.product_show_wishlist -%}
      <button class="prod-wish"
              aria-label="{{ product.title | escape }}をお気に入りに追加"
              data-product-id="{{ product.id }}">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
      </button>
    {%- endif -%}

    <!-- Quick Add -->
    {%- if settings.product_show_quick_add and product.available -%}
      {%- if product.variants.size == 1 -%}
        <button class="prod-quick"
                data-product-id="{{ product.id }}"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                onclick="quickAddToCart(this)">
          + カートに追加
        </button>
      {%- else -%}
        <a class="prod-quick" href="{{ product.url }}">オプションを選択</a>
      {%- endif -%}
    {%- endif -%}
  </div>

  <!-- Product Info -->
  <a href="{{ product.url }}" class="prod-info" aria-label="{{ product.title | escape }}の詳細を見る">
    {%- if settings.product_show_vendor and product.vendor != blank -%}
      <div class="prod-brand">{{ product.vendor }}</div>
    {%- endif -%}

    <div class="prod-name">{{ product.title }}</div>

    <div class="prod-price-row">
      {%- if product.compare_at_price > product.price -%}
        <span class="prod-price en">{{ product.price | money }}</span>
        <span class="prod-price-old en">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        <span class="prod-price en">{{ product.price | money }}</span>
      {%- endif -%}
    </div>

    {%- if settings.product_show_rating -%}
      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="prod-stars" aria-label="評価: {{ product.metafields.reviews.rating.value }}">
          {%- assign rating = product.metafields.reviews.rating.value | round -%}
          {%- for i in (1..5) -%}
            <span class="prod-star" style="color:{% if i <= rating %}var(--c-accent){% else %}var(--c-border){% endif %}">★</span>
          {%- endfor -%}
          {%- if product.metafields.reviews.rating_count.value != blank -%}
            <span class="prod-rev-count">({{ product.metafields.reviews.rating_count.value }})</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </a>

</div>
