{%- comment -%}
  fp-product-card.liquid
  Usage:
    {%- render 'fp-product-card',
      product: product,
      show_badge_new:  true,
      show_badge_sale: true,
      show_badge_best: false
    -%}
{%- endcomment -%}

{%- liquid
  assign card_product    = product
  assign price           = card_product.price
  assign compare_price   = card_product.compare_at_price
  assign on_sale         = false
  if compare_price > price
    assign on_sale = true
  endif
  assign sold_out        = false
  unless card_product.available
    assign sold_out = true
  endunless
  assign first_img       = card_product.featured_image
  assign second_img      = card_product.images[1]
  assign product_url     = card_product.url
  assign product_title   = card_product.title
  assign product_vendor  = card_product.vendor

  assign rating_val = card_product.metafields.reviews.rating.value
  assign rating_cnt = card_product.metafields.reviews.rating_count.value
-%}

<article
  class="fp-prod-card"
  itemscope
  itemtype="https://schema.org/Product"
  aria-label="{{ product_title | escape }}"
>
  <a href="{{ product_url }}" class="fp-prod-card__inner" tabindex="-1" aria-hidden="true">

    {%- comment -%} Image {%- endcomment -%}
    <div class="fp-prod-img-wrap">
      {%- if first_img -%}
        <img
          src="{{ first_img | image_url: width: 540 }}"
          srcset="
            {{ first_img | image_url: width: 360 }} 360w,
            {{ first_img | image_url: width: 540 }} 540w,
            {{ first_img | image_url: width: 720 }} 720w
          "
          sizes="(max-width:480px) 46vw, (max-width:768px) 44vw, 22vw"
          alt="{{ first_img.alt | escape | default: product_title }}"
          width="{{ first_img.width }}"
          height="{{ first_img.height }}"
          loading="lazy"
          class="fp-prod-img fp-prod-img--primary"
          itemprop="image"
        >
        {%- if second_img -%}
          <img
            src="{{ second_img | image_url: width: 540 }}"
            alt="{{ second_img.alt | escape | default: product_title }}"
            width="{{ second_img.width }}"
            height="{{ second_img.height }}"
            loading="lazy"
            class="fp-prod-img fp-prod-img--hover"
            aria-hidden="true"
          >
        {%- endif -%}
      {%- else -%}
        <div class="fp-prod-img-placeholder" aria-hidden="true">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- comment -%} Badges {%- endcomment -%}
      <div class="fp-prod-badges" aria-label="商品バッジ">
        {%- if sold_out -%}
          <span class="fp-prod-badge fp-prod-badge--soldout">{{ 'products.general.sold_out' | t | default: 'SOLD OUT' }}</span>
        {%- else -%}
          {%- if show_badge_new and card_product.created_at > 'now' | date: '%s' | minus: 2592000 | date: '%Y-%m-%dT%H:%M:%SZ' -%}
            <span class="fp-prod-badge fp-prod-badge--new">{{ 'products.general.new' | t | default: 'NEW' }}</span>
          {%- endif -%}
          {%- if show_badge_sale and on_sale -%}
            <span class="fp-prod-badge fp-prod-badge--sale">{{ 'products.general.sale' | t | default: 'SALE' }}</span>
          {%- endif -%}
          {%- if show_badge_best -%}
            <span class="fp-prod-badge fp-prod-badge--best">{{ 'products.general.best' | t | default: 'BEST' }}</span>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- comment -%} Wishlist button {%- endcomment -%}
      <button
        class="fp-prod-wish"
        aria-label="{{ 'products.general.wishlist_add' | t | default: 'お気に入りに追加' }}: {{ product_title | escape }}"
        data-product-id="{{ card_product.id }}"
        type="button"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 13.5S1.5 9.5 1.5 5.5a3.5 3.5 0 0 1 6.5-1.76A3.5 3.5 0 0 1 14.5 5.5C14.5 9.5 8 13.5 8 13.5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      {%- comment -%} Quick add {%- endcomment -%}
      {%- unless sold_out -%}
        <button
          class="fp-prod-quick"
          data-product-id="{{ card_product.id }}"
          data-variant-id="{{ card_product.selected_or_first_available_variant.id }}"
          aria-label="{{ 'products.general.quick_add' | t | default: 'クイック追加' }}: {{ product_title | escape }}"
          type="button"
        >
          {{ 'products.general.quick_add' | t | default: 'QUICK ADD' }}
        </button>
      {%- endunless -%}
    </div>

    {%- comment -%} Info {%- endcomment -%}
    <div class="fp-prod-info" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      {%- if product_vendor != blank -%}
        <p class="fp-prod-brand" itemprop="brand">{{ product_vendor }}</p>
      {%- endif -%}

      <h3 class="fp-prod-name" itemprop="name">
        <a href="{{ product_url }}">{{ product_title }}</a>
      </h3>

      <div class="fp-prod-price-row">
        <span
          class="fp-prod-price{% if on_sale %} fp-prod-price--sale{% endif %}"
          itemprop="price"
          content="{{ price | divided_by: 100.0 }}"
        >
          {{ price | money }}
        </span>
        {%- if on_sale -%}
          <s class="fp-prod-price-old" aria-label="{{ 'products.price.regular_price' | t | default: '通常価格' }}">
            {{ compare_price | money }}
          </s>
          <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        {%- endif -%}
      </div>

      {%- comment -%} Star rating from metafields {%- endcomment -%}
      {%- if rating_val != blank -%}
        <div
          class="fp-prod-stars"
          aria-label="{{ rating_val }}/5 （{{ rating_cnt }}件のレビュー）"
          role="img"
        >
          {%- assign rating_rounded = rating_val | round -%}
          {%- for i in (1..5) -%}
            <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              {%- if i <= rating_rounded -%}
                <path d="M6 1l1.3 2.6 2.9.4-2.1 2 .5 2.9L6 7.4 3.4 8.9l.5-2.9-2.1-2 2.9-.4L6 1z" fill="#CFAE6B"/>
              {%- else -%}
                <path d="M6 1l1.3 2.6 2.9.4-2.1 2 .5 2.9L6 7.4 3.4 8.9l.5-2.9-2.1-2 2.9-.4L6 1z" fill="none" stroke="#CFAE6B" stroke-width=".8"/>
              {%- endif -%}
            </svg>
          {%- endfor -%}
          {%- if rating_cnt != blank -%}
            <span class="fp-prod-rev-count">({{ rating_cnt }})</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <link itemprop="availability" href="{% if card_product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
    </div>

  </a>
</article>
