[
  {
    "name": "theme_info",
    "theme_name": "F'sPlanet",
    "theme_version": "2.0.0",
    "theme_author": "F'sPlanet",
    "theme_documentation_url": "https://fsplanet.jp",
    "theme_support_url": "https://fsplanet.jp/support"
  },
  {
    "name": "F'sPlanet カラー設定",
    "settings": [
      {
        "type": "header",
        "content": "ブランドカラー（--fp-* トークン）"
      },
      {
        "type": "color",
        "id": "fp_main",
        "label": "メインカラー（fp-main）",
        "default": "#62ADED",
        "info": "ヘッダー・バッジ・リンクのメインカラー"
      },
      {
        "type": "color",
        "id": "fp_sub",
        "label": "サブカラー（fp-sub）",
        "default": "#3E7CB1",
        "info": "ホバー・サブ要素カラー"
      },
      {
        "type": "color",
        "id": "fp_bg",
        "label": "背景色（fp-bg）",
        "default": "#FCFCFD",
        "info": "ページ全体の基本背景色"
      },
      {
        "type": "color",
        "id": "fp_accent",
        "label": "アクセントカラー（fp-accent）",
        "default": "#CFAE6B",
        "info": "見出し装飾・ランキング・星マークカラー"
      },
      {
        "type": "color",
        "id": "fp_btn",
        "label": "通常ボタン色（fp-btn）",
        "default": "#4A90E2",
        "info": "CTAボタン・リンクボタンのベースカラー"
      },
      {
        "type": "color",
        "id": "fp_buy",
        "label": "購入ボタン色（fp-buy）",
        "default": "#F2994A",
        "info": "カートに追加・購入ボタンのカラー"
      },
      {
        "type": "color",
        "id": "fp_text",
        "label": "テキストカラー（fp-text）",
        "default": "#222222",
        "info": "本文・見出しの基本テキストカラー"
      },
      {
        "type": "header",
        "content": "Dawn 互換カラー設定"
      },
      {
        "type": "color",
        "id": "color_main",
        "label": "メインカラー（Dawn互換）",
        "default": "#62ADED"
      },
      {
        "type": "color",
        "id": "color_sub",
        "label": "サブカラー（Dawn互換）",
        "default": "#3E7CB1"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "アクセントカラー（Dawn互換）",
        "default": "#CFAE6B"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "背景色（Dawn互換）",
        "default": "#FCFCFD"
      },
      {
        "type": "color",
        "id": "color_btn",
        "label": "通常ボタン色（Dawn互換）",
        "default": "#4A90E2"
      },
      {
        "type": "color",
        "id": "color_buy",
        "label": "購入ボタン色（Dawn互換）",
        "default": "#F2994A"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "テキストカラー（Dawn互換）",
        "default": "#222222"
      }
    ]
  },
  {
    "name": "タイポグラフィ設定",
    "settings": [
      {
        "type": "header",
        "content": "英字フォント"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "見出しフォント",
        "default": "cormorant_garamond_n4",
        "info": "英字見出しに使用（デフォルト: Cormorant Garamond）"
      },
      {
        "type": "header",
        "content": "日本語フォント"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "本文フォント",
        "default": "assistant_n4",
        "info": "Noto Sans JP は @import で読み込まれます"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "基本フォントサイズ",
        "default": 16
      }
    ]
  },
  {
    "name": "ファビコン",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "ファビコン画像",
        "info": "32×32px PNG 推奨"
      }
    ]
  },
  {
    "name": "SNS設定",
    "settings": [
      {
        "type": "header",
        "content": "SNSリンク"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL",
        "default": "https://www.instagram.com/fsplanet_official/"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter / X URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_line",
        "label": "LINE Official URL"
      }
    ]
  },
  {
    "name": "ショッピング設定",
    "settings": [
      {
        "type": "header",
        "content": "カート設定"
      },
      {
        "type": "select",
        "id": "cart_type",
        "label": "カートの種類",
        "options": [
          { "value": "drawer", "label": "ドロワー（スライドイン）" },
          { "value": "page", "label": "カートページ" },
          { "value": "notification", "label": "通知バー" }
        ],
        "default": "notification"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "カートメモを表示",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "enable_gift_wrap",
        "label": "ギフトラッピングオプションを表示",
        "default": true
      },
      {
        "type": "header",
        "content": "商品設定"
      },
      {
        "type": "checkbox",
        "id": "show_product_rating",
        "label": "商品評価を表示（metafields連携）",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_quick_add",
        "label": "クイック追加ボタンを表示",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_wishlist",
        "label": "ウィッシュリストボタンを表示",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "ブランド名を表示",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_sale_badge",
        "label": "セールバッジを表示",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_new_badge",
        "label": "NEWバッジを表示",
        "default": true
      }
    ]
  },
  {
    "name": "アニメーション設定",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_scroll_reveal",
        "label": "スクロールアニメーションを有効化",
        "default": true,
        "info": "prefers-reduced-motion が設定されている場合は自動的に無効になります"
      },
      {
        "type": "checkbox",
        "id": "enable_hover_effects",
        "label": "ホバーエフェクトを有効化",
        "default": true
      }
    ]
  },
  {
    "name": "SEO設定",
    "settings": [
      {
        "type": "checkbox",
        "id": "seo_structured_data",
        "label": "構造化データ（Schema.org）を出力",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "seo_open_graph",
        "label": "Open Graphタグを出力",
        "default": true
      },
      {
        "type": "text",
        "id": "seo_default_title_suffix",
        "label": "タイトルの接尾辞",
        "default": "F'sPlanet",
        "info": "「商品名 | F'sPlanet」のような形式で使用"
      }
    ]
  },
  {
    "name": "カスタムコード",
    "settings": [
      {
        "type": "html",
        "id": "custom_head_code",
        "label": "<head> に追加するコード",
        "info": "Google Tag Manager や追加CSSなどを入力"
      },
      {
        "type": "html",
        "id": "custom_body_end_code",
        "label": "</body> 直前に追加するコード",
        "info": "チャットウィジェットや計測コードを入力"
      }
    ]
  }
]
