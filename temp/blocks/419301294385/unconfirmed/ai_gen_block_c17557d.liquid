{% doc %}
  @prompt
    Gift Guideと全く一緒でギフトカートの選択をコレクションリストに変更して
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gift-guide-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-gift-guide-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-gift-guide-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-gift-guide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-gift-guide-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-gift-guide-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  .ai-gift-guide-card-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }

  .ai-gift-guide-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-gift-guide-card-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-gift-guide-card-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-gift-guide-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-gift-guide-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-gift-guide-card-content-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-gift-guide-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-gift-guide-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.card_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-gift-guide-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-gift-guide-empty-state-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  .ai-gift-guide-empty-message-{{ ai_gen_id }} {
    font-size: 16px;
    color: #999;
  }

  @media screen and (max-width: 989px) {
    .ai-gift-guide-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-gift-guide-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-gift-guide-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-gift-guide-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-gift-guide-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<gift-guide-{{ ai_gen_id }} class="ai-gift-guide-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gift-guide-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-gift-guide-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-gift-guide-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-gift-guide-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collections != blank and block.settings.collections.size > 0 %}
      <div class="ai-gift-guide-grid-{{ ai_gen_id }}">
        {% for collection in block.settings.collections %}
          <a href="{{ collection.url }}" class="ai-gift-guide-card-{{ ai_gen_id }}">
            <div class="ai-gift-guide-card-image-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 600 }}"
                  alt="{{ collection.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-gift-guide-card-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-gift-guide-card-content-{{ ai_gen_id }}">
              <h3 class="ai-gift-guide-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              {% if collection.description != blank %}
                <p class="ai-gift-guide-card-text-{{ ai_gen_id }}">
                  {{ collection.description | strip_html | truncate: 80 }}
                </p>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-gift-guide-empty-state-{{ ai_gen_id }}">
        {{ 'collection-1' | placeholder_svg_tag }}
        <p class="ai-gift-guide-empty-message-{{ ai_gen_id }}">
          コレクションを選択してギフトガイドを作成しましょう
        </p>
      </div>
    {% endif %}
  </div>
</gift-guide-{{ ai_gen_id }}>

<script>
  (function() {
    class GiftGuide{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-gift-guide-card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'link');
        });
      }
    }

    customElements.define('gift-guide-{{ ai_gen_id }}', GiftGuide{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "ギフトガイド",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "タイトル",
      "default": "ギフトガイド"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "説明文",
      "default": "<p>大切な人へ、心を込めたギフトを見つけましょう</p>"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "コレクション",
      "limit": 12
    },
    {
      "type": "header",
      "content": "レイアウト"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "デスクトップ列数",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "タブレット列数",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "モバイル列数",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "セクション余白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "ヘッダー下余白",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "グリッド間隔",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "カードスタイル"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "カード角丸",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "カード背景色",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "カラー"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景色",
      "default": "#FCFCFD"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "タイトル色",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "説明文色",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "カードタイトル色",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "カードテキスト色",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "タイポグラフィ"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "タイトルサイズ",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "説明文サイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "カードタイトルサイズ",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_text_size",
      "label": "カードテキストサイズ",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "ギフトガイド"
    }
  ]
}
{% endschema %}
