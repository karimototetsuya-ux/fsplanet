{% doc %}
  @prompt
    gift Guideを参考にコレクションリストを生成して
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gift-guide-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-gift-guide-container-{{ ai_gen_id }} {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-gift-guide-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-gift-guide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 300;
    letter-spacing: 0.08em;
  }

  .ai-gift-guide-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-gift-guide-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-gift-guide-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_bg_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-gift-guide-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-gift-guide-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-gift-guide-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-gift-guide-card-{{ ai_gen_id }}:hover .ai-gift-guide-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-gift-guide-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-gift-guide-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-gift-guide-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    z-index: 2;
  }

  .ai-gift-guide-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-gift-guide-category-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.category_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-gift-guide-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-gift-guide-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 20px;
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-gift-guide-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: gap 0.3s ease;
  }

  .ai-gift-guide-link-{{ ai_gen_id }}:hover {
    gap: 12px;
  }

  .ai-gift-guide-link-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-gift-guide-link-{{ ai_gen_id }}:hover svg {
    transform: translateX(4px);
  }

  .ai-gift-guide-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #888;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-gift-guide-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-gift-guide-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-gift-guide-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-gift-guide-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-gift-guide-card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.9);
    }
  }
{% endstyle %}

<gift-guide-{{ ai_gen_id }} class="ai-gift-guide-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gift-guide-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-gift-guide-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-gift-guide-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-gift-guide-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% assign has_collections = false %}
    {% for i in (1..6) %}
      {% assign collection_key = 'collection_' | append: i %}
      {% if block.settings[collection_key] != blank %}
        {% assign has_collections = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if has_collections %}
      <div class="ai-gift-guide-grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% assign collection_key = 'collection_' | append: i %}
          {% assign badge_key = 'badge_' | append: i %}
          {% assign category_key = 'category_' | append: i %}
          {% assign description_key = 'description_' | append: i %}
          
          {% assign collection = block.settings[collection_key] %}
          {% assign badge_text = block.settings[badge_key] %}
          {% assign category_text = block.settings[category_key] %}
          {% assign description_text = block.settings[description_key] %}

          {% if collection != blank %}
            <div class="ai-gift-guide-card-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-gift-guide-image-wrapper-{{ ai_gen_id }}">
                {% if badge_text != blank %}
                  <div class="ai-gift-guide-badge-{{ ai_gen_id }}">{{ badge_text }}</div>
                {% endif %}
                
                {% if collection.featured_image %}
                  <img
                    src="{{ collection.featured_image | image_url: width: 800 }}"
                    alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                    class="ai-gift-guide-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | times: block.settings.image_ratio | divided_by: 100 }}"
                  >
                {% else %}
                  <div class="ai-gift-guide-placeholder-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </a>

              <div class="ai-gift-guide-content-{{ ai_gen_id }}">
                {% if category_text != blank %}
                  <div class="ai-gift-guide-category-{{ ai_gen_id }}">{{ category_text }}</div>
                {% endif %}

                <h3 class="ai-gift-guide-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>

                {% if description_text != blank %}
                  <div class="ai-gift-guide-description-{{ ai_gen_id }}">{{ description_text }}</div>
                {% elsif collection.description != blank %}
                  <div class="ai-gift-guide-description-{{ ai_gen_id }}">{{ collection.description | strip_html | truncate: 100 }}</div>
                {% endif %}

                <a href="{{ collection.url }}" class="ai-gift-guide-link-{{ ai_gen_id }}">
                  {{ block.settings.link_text }}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-gift-guide-empty-state-{{ ai_gen_id }}">
        コレクションを選択してギフトガイドを作成してください
      </div>
    {% endif %}
  </div>
</gift-guide-{{ ai_gen_id }}>

<script>
  (function() {
    class GiftGuide{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-gift-guide-card-{{ ai_gen_id }}');
        this.setupAnimations();
      }

      setupAnimations() {
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
              if (entry.isIntersecting) {
                setTimeout(() => {
                  entry.target.style.opacity = '1';
                  entry.target.style.transform = 'translateY(0)';
                }, index * 100);
                observer.unobserve(entry.target);
              }
            });
          }, {
            threshold: 0.1
          });

          this.cards.forEach((card) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            observer.observe(card);
          });
        }
      }
    }

    customElements.define('gift-guide-{{ ai_gen_id }}', GiftGuide{{ ai_gen_id }});
  })();
</script>

